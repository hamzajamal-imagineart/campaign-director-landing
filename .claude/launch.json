{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "landing-page",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; p=int(os.environ.get('PORT',8080)); s=socketserver.TCPServer(('',p),http.server.SimpleHTTPRequestHandler); s.serve_forever()"],
